(export (version "E")
  (design
    (source "Metronome")
    (tool "wirebench 0.x"))
  (components
    (comp (ref "C1")
      (value "1e-07") (footprint "Capacitor_SMD:C_0603_1608Metric") (libsource (lib "Device") (part "C") (description "Capacitor"))
      (sheetpath (names "/") (tstamps "/")))
    (comp (ref "C2")
      (value "1e-08") (footprint "Capacitor_SMD:C_0603_1608Metric") (libsource (lib "Device") (part "C") (description "Capacitor"))
      (sheetpath (names "/") (tstamps "/")))
    (comp (ref "C3")
      (value "1e-05") (footprint "Capacitor_SMD:C_0603_1608Metric") (libsource (lib "Device") (part "C") (description "Capacitor"))
      (sheetpath (names "/") (tstamps "/")))
    (comp (ref "LS1")
      (value "8") (footprint "Buzzer_Beeper:Speaker_Mallory_M9CP-916H_15mm") (libsource (lib "Device") (part "Speaker") (description "Speaker"))
      (sheetpath (names "/") (tstamps "/")))
    (comp (ref "R1")
      (value "4700") (footprint "Resistor_SMD:R_0603_1608Metric") (libsource (lib "Device") (part "R") (description "Resistor"))
      (sheetpath (names "/") (tstamps "/")))
    (comp (ref "R2")
      (value "50000") (footprint "Resistor_SMD:R_0603_1608Metric") (libsource (lib "Device") (part "R") (description "Resistor"))
      (sheetpath (names "/") (tstamps "/")))
    (comp (ref "R3")
      (value "100") (footprint "Resistor_SMD:R_0603_1608Metric") (libsource (lib "Device") (part "R") (description "Resistor"))
      (sheetpath (names "/") (tstamps "/")))
    (comp (ref "U1")
      (value "NE555") (footprint "Package_DIP:DIP-8_W7.62mm") (libsource (lib "IC") (part "NE555") (description "NE555"))
      (sheetpath (names "/") (tstamps "/")))
  )
  (nets
    (net (code "1") (name "GND")
      (node (ref "C1") (pin "2") (pintype "passive"))
      (node (ref "C2") (pin "2") (pintype "passive"))
      (node (ref "LS1") (pin "2") (pintype "passive"))
      (node (ref "U1") (pin "1") (pintype "input"))
    )
    (net (code "2") (name "Net-(C1-Pad1)")
      (node (ref "C1") (pin "1") (pintype "passive"))
      (node (ref "R2") (pin "2") (pintype "passive"))
      (node (ref "U1") (pin "2") (pintype "input"))
      (node (ref "U1") (pin "6") (pintype "input"))
    )
    (net (code "3") (name "Net-(C2-Pad1)")
      (node (ref "C2") (pin "1") (pintype "passive"))
      (node (ref "U1") (pin "5") (pintype "bidirectional"))
    )
    (net (code "4") (name "Net-(C3-Pad1)")
      (node (ref "C3") (pin "1") (pintype "passive"))
      (node (ref "R3") (pin "2") (pintype "passive"))
    )
    (net (code "5") (name "Net-(C3-Pad2)")
      (node (ref "C3") (pin "2") (pintype "passive"))
      (node (ref "LS1") (pin "1") (pintype "passive"))
    )
    (net (code "6") (name "Net-(R1-Pad2)")
      (node (ref "R1") (pin "2") (pintype "passive"))
      (node (ref "R2") (pin "1") (pintype "passive"))
      (node (ref "U1") (pin "7") (pintype "output"))
    )
    (net (code "7") (name "Net-(R3-Pad1)")
      (node (ref "R3") (pin "1") (pintype "passive"))
      (node (ref "U1") (pin "3") (pintype "output"))
    )
    (net (code "8") (name "vcc")
      (node (ref "R1") (pin "1") (pintype "passive"))
      (node (ref "U1") (pin "4") (pintype "input"))
      (node (ref "U1") (pin "8") (pintype "input"))
    )
  )
)
