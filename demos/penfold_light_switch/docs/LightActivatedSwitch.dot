digraph "LightActivatedSwitch" {
  rankdir=TB;
  node [shape=box, fontname="monospace"];
  U1 [label="U1\\nLM741"];
  R2 [label="R2\\nLDR"];
  R1 [label="R1\\n10000Ω"];
  R3 [label="R3\\n10000Ω"];
  R4 [label="R4\\n5000Ω"];
  Q1 [label="Q1\\nBC547"];
  R5 [label="R5\\n4700Ω"];
  R6 [label="R6\\n470Ω"];
  D1 [label="D1\\nred LED"];
  // Nets
  node [shape=circle, label="", width=0.15, fixedsize=true];
  gnd; net_0; net_1; net_3; net_4; net_6; net_8; vcc;
  // Edges (component -- net, taillabel = port name)
  edge [arrowhead=none, fontname="monospace", fontsize=9];
  D1 -> net_0 [taillabel="anode"];
  D1 -> net_1 [taillabel="cathode"];
  Q1 -> net_4 [taillabel="b"];
  Q1 -> net_1 [taillabel="c"];
  Q1 -> gnd [taillabel="e"];
  R1 -> net_8 [taillabel="t1"];
  R1 -> gnd [taillabel="t2"];
  R2 -> vcc [taillabel="t1"];
  R2 -> net_8 [taillabel="t2"];
  R3 -> vcc [taillabel="t1"];
  R3 -> net_6 [taillabel="t2"];
  R4 -> net_6 [taillabel="t1"];
  R4 -> gnd [taillabel="t2"];
  R5 -> net_3 [taillabel="t1"];
  R5 -> net_4 [taillabel="t2"];
  R6 -> vcc [taillabel="t1"];
  R6 -> net_0 [taillabel="t2"];
  U1 -> net_6 [taillabel="IN_NEG"];
  U1 -> net_8 [taillabel="IN_POS"];
  U1 -> net_3 [taillabel="OUT"];
  U1 -> gnd [taillabel="V_NEG"];
  U1 -> vcc [taillabel="V_POS"];
}
