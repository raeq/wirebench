(export (version "E")
  (design
    (source "LightActivatedSwitch")
    (tool "wirebench 0.x"))
  (components
    (comp (ref "D1")
      (value "red") (footprint "LED_SMD:LED_0805") (libsource (lib "Device") (part "LED") (description "Light-emitting diode"))
      (sheetpath (names "/") (tstamps "/")))
    (comp (ref "Q1")
      (value "BC547") (footprint "Package_TO_SOT_THT:TO-92_Inline") (libsource (lib "Device") (part "BC547") (description "BC547"))
      (sheetpath (names "/") (tstamps "/")))
    (comp (ref "R1")
      (value "10000") (footprint "Resistor_SMD:R_0603_1608Metric") (libsource (lib "Device") (part "R") (description "Resistor"))
      (sheetpath (names "/") (tstamps "/")))
    (comp (ref "R2")
      (value "LDR_1e+06/400") (footprint "Resistor_THT:R_Axial_DIN0309_L9.0mm_D3.2mm_P12.70mm_Horizontal") (libsource (lib "Device") (part "R_Photo") (description "Photoresistor (LDR)"))
      (sheetpath (names "/") (tstamps "/")))
    (comp (ref "R3")
      (value "10000") (footprint "Resistor_SMD:R_0603_1608Metric") (libsource (lib "Device") (part "R") (description "Resistor"))
      (sheetpath (names "/") (tstamps "/")))
    (comp (ref "R4")
      (value "5000") (footprint "Resistor_SMD:R_0603_1608Metric") (libsource (lib "Device") (part "R") (description "Resistor"))
      (sheetpath (names "/") (tstamps "/")))
    (comp (ref "R5")
      (value "4700") (footprint "Resistor_SMD:R_0603_1608Metric") (libsource (lib "Device") (part "R") (description "Resistor"))
      (sheetpath (names "/") (tstamps "/")))
    (comp (ref "R6")
      (value "470") (footprint "Resistor_SMD:R_0603_1608Metric") (libsource (lib "Device") (part "R") (description "Resistor"))
      (sheetpath (names "/") (tstamps "/")))
    (comp (ref "U1")
      (value "LM741") (footprint "Package_DIP:DIP-8_W7.62mm") (libsource (lib "IC") (part "LM741") (description "LM741"))
      (sheetpath (names "/") (tstamps "/")))
  )
  (nets
    (net (code "1") (name "GND")
      (node (ref "Q1") (pin "3") (pintype "passive"))
      (node (ref "R1") (pin "2") (pintype "passive"))
      (node (ref "R4") (pin "2") (pintype "passive"))
      (node (ref "U1") (pin "4") (pintype "input"))
    )
    (net (code "2") (name "Net-(D1-Pad1)")
      (node (ref "D1") (pin "1") (pintype "input"))
      (node (ref "R6") (pin "2") (pintype "passive"))
    )
    (net (code "3") (name "Net-(D1-Pad2)")
      (node (ref "D1") (pin "2") (pintype "input"))
      (node (ref "Q1") (pin "1") (pintype "passive"))
    )
    (net (code "4") (name "Net-(Q1-Pad2)")
      (node (ref "Q1") (pin "2") (pintype "passive"))
      (node (ref "R5") (pin "2") (pintype "passive"))
    )
    (net (code "5") (name "Net-(R1-Pad1)")
      (node (ref "R1") (pin "1") (pintype "passive"))
      (node (ref "R2") (pin "2") (pintype "passive"))
      (node (ref "U1") (pin "3") (pintype "input"))
    )
    (net (code "6") (name "Net-(R3-Pad2)")
      (node (ref "R3") (pin "2") (pintype "passive"))
      (node (ref "R4") (pin "1") (pintype "passive"))
      (node (ref "U1") (pin "2") (pintype "input"))
    )
    (net (code "7") (name "Net-(R5-Pad1)")
      (node (ref "R5") (pin "1") (pintype "passive"))
      (node (ref "U1") (pin "6") (pintype "output"))
    )
    (net (code "8") (name "vcc")
      (node (ref "R2") (pin "1") (pintype "passive"))
      (node (ref "R3") (pin "1") (pintype "passive"))
      (node (ref "R6") (pin "1") (pintype "passive"))
      (node (ref "U1") (pin "7") (pintype "input"))
    )
  )
)
