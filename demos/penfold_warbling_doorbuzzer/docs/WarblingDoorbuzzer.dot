  C5 -> net_2 [taillabel="t1"];
  C5 -> net_0 [taillabel="t2"];
  LS1 -> net_0 [taillabel="t1"];
  LS1 -> gnd [taillabel="t2"];
  R1 -> vcc [taillabel="t1"];
  R1 -> net_10 [taillabel="t2"];
  R2 -> net_10 [taillabel="t1"];
  R2 -> net_9 [taillabel="t2"];
  R3 -> vcc [taillabel="t1"];
  R3 -> net_6 [taillabel="t2"];
  R4 -> net_6 [taillabel="t1"];
  R4 -> net_5 [taillabel="t2"];
  R5 -> net_3 [taillabel="t1"];
  R5 -> net_2 [taillabel="t2"];
  U1 -> net_8 [taillabel="CONT"];
