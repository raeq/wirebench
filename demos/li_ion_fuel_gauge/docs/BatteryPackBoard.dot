  C3 -> net_4 [taillabel="t1"];
  C3 -> net_3 [taillabel="t2"];
  R1 -> net_3 [taillabel="t1"];
  R1 -> net_3 [taillabel="t2"];
  R2 -> net_6 [taillabel="t1"];
  R2 -> net_3 [taillabel="t2"];
  R3 -> net_0 [taillabel="t1"];
  R3 -> net_5 [taillabel="t2"];
  R4 -> net_1 [taillabel="t1"];
  R4 -> net_5 [taillabel="t2"];
  R5 -> net_2 [taillabel="t1"];
  R5 -> net_5 [taillabel="t2"];
  U1 -> net_4 [taillabel="BAT"];
  U1 -> net_2 [taillabel="HDQ"];
  U1 -> net_4 [taillabel="REGIN"];
  U1 -> net_1 [taillabel="SCL"];
  U1 -> net_0 [taillabel="SDA"];
  U1 -> net_3 [taillabel="SRN"];
