(export (version "E")
  (design
    (source "FiveVoltRailPower")
    (tool "circuitry 0.x"))
  (components
    
    (comp (ref "C1")
      (value "1e-07") (footprint "Capacitor_SMD:C_0603_1608Metric") (libsource (lib "Device") (part "C") (description "Capacitor"))
      (sheetpath (names "/") (tstamps "/")))
    (comp (ref "C2")
      (value "1e-05") (footprint "Capacitor_SMD:C_0603_1608Metric") (libsource (lib "Device") (part "C") (description "Capacitor"))
      (sheetpath (names "/") (tstamps "/")))
    (comp (ref "D1")
      (value "D1N5817") (footprint "Diode_THT:D_DO-41_SOD81_P10.16mm_Horizontal") (libsource (lib "Device") (part "D1N5817") (description "D1N5817"))
      (sheetpath (names "/") (tstamps "/")))
    (comp (ref "D2")
      (value "D1N4733A") (footprint "Diode_THT:D_DO-41_SOD81_P10.16mm_Horizontal") (libsource (lib "Device") (part "D1N4733A") (description "D1N4733A"))
      (sheetpath (names "/") (tstamps "/")))
    (comp (ref "D3")
      (value "green") (footprint "LED_SMD:LED_0805") (libsource (lib "Device") (part "LED") (description "Light-emitting diode"))
      (sheetpath (names "/") (tstamps "/")))
    (comp (ref "P1")
      (value "Header1xNMale_2") (footprint "Connector_PinHeader_2.54mm:PinHeader_1x02_P2.54mm_Vertical") (libsource (lib "Connector") (part "Header1xNMale") (description "Header1xNMale"))
      (sheetpath (names "/") (tstamps "/")))
    (comp (ref "R1")
      (value "470") (footprint "Resistor_SMD:R_0603_1608Metric") (libsource (lib "Device") (part "R") (description "Resistor"))
      (sheetpath (names "/") (tstamps "/")))
    (comp (ref "U1")
      (value "LM7805") (footprint "Package_TO_SOT_THT:TO-220-3_Vertical") (libsource (lib "IC") (part "LM7805") (description "LM7805"))
      (sheetpath (names "/") (tstamps "/")))
  )
  (nets
    (net (code "1") (name "Net-(BT1-Pad1)")
      (node (ref "BT1") (pin "1") (pintype "output"))
    )
    (net (code "2") (name "Net-(BT1-Pad2)")
      (node (ref "BT1") (pin "2") (pintype "output"))
      (node (ref "C1") (pin "2") (pintype "passive"))
      (node (ref "C2") (pin "2") (pintype "passive"))
      (node (ref "D2") (pin "1") (pintype "passive"))
      (node (ref "D3") (pin "2") (pintype "input"))
      (node (ref "U1") (pin "2") (pintype "input"))
    )
    (net (code "3") (name "Net-(C1-Pad1)")
      (node (ref "C1") (pin "1") (pintype "passive"))
      (node (ref "D1") (pin "2") (pintype "passive"))
      (node (ref "U1") (pin "1") (pintype "input"))
    )
    (net (code "4") (name "Net-(C2-Pad1)")
      (node (ref "C2") (pin "1") (pintype "passive"))
      (node (ref "D2") (pin "2") (pintype "passive"))
      (node (ref "R1") (pin "1") (pintype "passive"))
      (node (ref "U1") (pin "3") (pintype "output"))
    )
    (net (code "5") (name "Net-(D1-Pad1)")
      (node (ref "D1") (pin "1") (pintype "passive"))
    )
    (net (code "6") (name "Net-(D3-Pad1)")
      (node (ref "D3") (pin "1") (pintype "input"))
      (node (ref "R1") (pin "2") (pintype "passive"))
    )
    (net (code "7") (name "Net-(P1-Pad1)")
      (node (ref "P1") (pin "1") (pintype "passive"))
      (node (ref "P1") (pin "2") (pintype "passive"))
    )
  )
)
