(export (version "E")
  (design
    (source "CrystalSet")
    (tool "wirebench 0.x"))
  (components
    (comp (ref "A1")
      (value "Antenna") (libsource (lib "Device") (part "Antenna") (description "Antenna (environment-fed)"))
      (sheetpath (names "/") (tstamps "/")))
    (comp (ref "BZ1")
      (value "32000") (footprint "Connector_Audio:Jack_3.5mm_QingPu_WQP-PJ398SM_Vertical") (libsource (lib "Device") (part "Speaker_Crystal") (description "Crystal earpiece (high-Z)"))
      (sheetpath (names "/") (tstamps "/")))
    (comp (ref "C1")
      (value "1e-11/3e-10") (footprint "Connector:Conn_01x02_Pin") (libsource (lib "Device") (part "C_Variable") (description "Variable capacitor"))
      (sheetpath (names "/") (tstamps "/")))
    (comp (ref "D1")
      (value "D_OA90") (footprint "Diode_THT:D_DO-35_SOD27_P7.62mm_Horizontal") (libsource (lib "Device") (part "D_OA90") (description "D_OA90"))
      (sheetpath (names "/") (tstamps "/")))
    (comp (ref "E1")
      (value "Earth") (libsource (lib "power") (part "Earth") (description "Earth-ground"))
      (sheetpath (names "/") (tstamps "/")))
    (comp (ref "L1")
      (value "0.0004") (footprint "Connector:Conn_01x02_Pin") (libsource (lib "Device") (part "L_Ferrite") (description "Ferrite-rod aerial coil"))
      (sheetpath (names "/") (tstamps "/")))
    (comp (ref "R1")
      (value "100000") (footprint "Resistor_SMD:R_0603_1608Metric") (libsource (lib "Device") (part "R") (description "Resistor"))
      (sheetpath (names "/") (tstamps "/")))
  )
  (nets
    (net (code "1") (name "Net-(A1-Pad1)")
      (node (ref "A1") (pin "1") (pintype "output"))
      (node (ref "C1") (pin "1") (pintype "passive"))
      (node (ref "D1") (pin "1") (pintype "passive"))
      (node (ref "L1") (pin "1") (pintype "passive"))
    )
    (net (code "2") (name "Net-(BZ1-Pad1)")
      (node (ref "BZ1") (pin "1") (pintype "passive"))
      (node (ref "D1") (pin "2") (pintype "passive"))
      (node (ref "R1") (pin "1") (pintype "passive"))
    )
    (net (code "3") (name "Net-(BZ1-Pad2)")
      (node (ref "BZ1") (pin "2") (pintype "passive"))
      (node (ref "C1") (pin "2") (pintype "passive"))
      (node (ref "E1") (pin "1") (pintype "output"))
      (node (ref "L1") (pin "2") (pintype "passive"))
      (node (ref "R1") (pin "2") (pintype "passive"))
    )
  )
)
