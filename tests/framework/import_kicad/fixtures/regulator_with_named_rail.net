(export (version "E")
  (design
    (source "RegulatorWithNamedRail")
    (tool "wirebench 0.x"))
  (components
    (comp (ref "U1")
      (value "LM7805") (footprint "Package_TO_SOT_THT:TO-220-3_Vertical")
      (libsource (lib "Regulator_Linear") (part "LM7805")))
    (comp (ref "C1")
      (value "330n") (footprint "Capacitor_SMD:C_0805_2012Metric")
      (libsource (lib "Device") (part "C")))
    (comp (ref "C2")
      (value "100n") (footprint "Capacitor_SMD:C_0805_2012Metric")
      (libsource (lib "Device") (part "C")))
    (comp (ref "R1")
      (value "1k") (footprint "Resistor_SMD:R_0603_1608Metric")
      (libsource (lib "Device") (part "R")))
    (comp (ref "D1")
      (value "red") (footprint "LED_SMD:LED_0805")
      (libsource (lib "Device") (part "LED")))
  )
  (nets
    (net (code "1") (name "VIN")
      (node (ref "U1") (pin "1") (pinfunction "INPUT") (pintype "input"))
      (node (ref "C1") (pin "1") (pintype "passive"))
    )
    (net (code "2") (name "GND")
      (node (ref "U1") (pin "2") (pinfunction "GND") (pintype "input"))
      (node (ref "C1") (pin "2") (pintype "passive"))
      (node (ref "C2") (pin "2") (pintype "passive"))
      (node (ref "D1") (pin "2") (pintype "input"))
    )
    (net (code "3") (name "+5V")
      (node (ref "U1") (pin "3") (pinfunction "OUTPUT") (pintype "output"))
      (node (ref "C2") (pin "1") (pintype "passive"))
      (node (ref "R1") (pin "1") (pintype "passive"))
    )
    (net (code "4") (name "Net-(R1-Pad2)")
      (node (ref "R1") (pin "2") (pintype "passive"))
      (node (ref "D1") (pin "1") (pintype "input"))
    )
  )
)
